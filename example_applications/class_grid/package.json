{
    "name": "simple_grid",
    "version": "1.0.0",
    "description": "The most basic grid application ever!",
    "main": "Simple-Grid-Application.js",
    "scripts": {
        "start": "node Simple-Grid-Application.js",
        "build": "npx quack build && npx quack copy"
    },
    "author": "steven",
    "license": "MIT",
    "retold": {
        "ExampleApplication": {
            "Stage": true,
            "Title": "Class Grid",
            "Summary": "The minimum-viable TuiGrid: ten student records edited via text, select, number, and date-picker editors with currency formatting and solver triggers.",
            "Complexity": "Basic"
        }
    },
    "copyFilesSettings": {
        "whenFileExists": "overwrite"
    },
    "copyFiles": [
        {
            "from": "./html/*",
            "to": "./dist/"
        },
        {
            "from": "./node_modules/tui-grid/dist/*",
            "to": "./dist/"
        },
        {
            "from": "./node_modules/tui-date-picker/dist/*",
            "to": "./dist/"
        },
        {
            "from": "../../node_modules/pict/dist/*",
            "to": "./dist/"
        }
    ],
    "dependencies": {
        "pict": "^1.0.210",
        "pict-application": "^1.0.19",
        "pict-view": "^1.0.51",
        "tui-grid": "^4.21.22"
    }
}
